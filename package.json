{
  "name": "cut-and-convert-videos",
  "version": "0.1.0",
  "description": "Lightweight Electron, React and Zig desktop video cutter and WebM encoder.",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 tsc -p tsconfig.main.json && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "zig:build": "cd zig-webm && zig build -Doptimize=ReleaseFast",
    "start": "electron .",
    "test:parsers": "tsx --test tests/parser.test.ts"
  },
  "keywords": [
    "electron",
    "react",
    "zig",
    "ffmpeg",
    "webm"
  ],
  "author": "",
  "license": "Unlicense",
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "electron": "^30.5.1",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "postcss": "latest",
    "tailwindcss": "latest",
    "tsx": "^4.23.1",
    "typescript": "latest",
    "vite": "latest",
    "wait-on": "latest"
  }
}
